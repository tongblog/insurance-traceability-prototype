<!-- ======== 思维导图视图 ======== -->

<div class="header">
  <h1>互联网保险投保可回溯流程思维导图</h1>
  <p>基于银保监发〔2020〕26号监管要求的完整操作节点映射</p>
</div>

<div class="legend">
  <div class="legend-item"><div class="legend-dot" style="background:#E53935;"></div> 截图节点</div>
  <div class="legend-item"><div class="legend-dot" style="background:#FF9800;"></div> 仅记录节点</div>
  <div class="legend-item"><div class="legend-dot" style="background:#6A1B9A;"></div> 混合节点</div>
  <div class="legend-item"><div class="legend-line" style="background:#E53935;"></div> 截图连线</div>
  <div class="legend-item"><div class="legend-line-dash"></div> 仅记录连线</div>
</div>

<div class="svg-wrap">
<svg xmlns="http://www.w3.org/2000/svg" width="1100" height="720">
  <defs>
    <marker id="arrowRed" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
      <path d="M0,0 L8,3 L0,6 Z" fill="#E53935"/>
    </marker>
    <marker id="arrowBlue" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
      <path d="M0,0 L8,3 L0,6 Z" fill="#2196F3"/>
    </marker>
    <marker id="arrowOrange" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
      <path d="M0,0 L8,3 L0,6 Z" fill="#FF9800"/>
    </marker>
    <filter id="shadow">
      <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#00000020"/>
    </filter>
  </defs>

  <script type="text/javascript"><![CDATA[
    var ns = "http://www.w3.org/2000/svg";

    function rect(x, y, w, h, fill, stroke, rx) {
      var r = document.createElementNS(ns, "rect");
      r.setAttribute("x", x); r.setAttribute("y", y);
      r.setAttribute("width", w); r.setAttribute("height", h);
      r.setAttribute("rx", rx||8); r.setAttribute("fill", fill);
      r.setAttribute("stroke", stroke||"#CCC"); r.setAttribute("stroke-width", "2");
      r.setAttribute("filter", "url(#shadow)");
      document.getElementById("g1").appendChild(r);
    }

    function text(x, y, content, size, weight, fill, anchor) {
      var t = document.createElementNS(ns, "text");
      t.setAttribute("x", x); t.setAttribute("y", y);
      t.setAttribute("font-size", size||12); t.setAttribute("font-weight", weight||600);
      t.setAttribute("fill", fill||"#333"); t.setAttribute("text-anchor", anchor||"middle");
      t.textContent = content;
      document.getElementById("g1").appendChild(t);
    }

    function line(x1, y1, x2, y2, color, dashed) {
      var l = document.createElementNS(ns, "line");
      l.setAttribute("x1", x1); l.setAttribute("y1", y1);
      l.setAttribute("x2", x2); l.setAttribute("y2", y2);
      l.setAttribute("stroke", color); l.setAttribute("stroke-width", "2");
      if (dashed) l.setAttribute("stroke-dasharray", "6,3");
      l.setAttribute("marker-end", "url(#arrow" + (color==="#E53935"?"Red":color==="#2196F3"?"Blue":"Orange") + ")");
      document.getElementById("g1").appendChild(l);
    }

    function label(x, y, content, color) {
      var t = document.createElementNS(ns, "text");
      t.setAttribute("x", x); t.setAttribute("y", y);
      t.setAttribute("font-size", 10); t.setAttribute("fill", color||"#999");
      t.setAttribute("text-anchor", "middle");
      t.textContent = content;
      document.getElementById("g1").appendChild(t);
    }

    // ===== 画整个思维导图 =====
    // 根节点
    rect(480, 20, 140, 48, "#E53935", "#AB000D", 10);
    text(550, 50, "开始投保", 15, 700, "white", "middle");

    // --- 第一层：点击立即投保 + 客户告知书 ---
    // 点击立即投保（仅记录，不截图）
    rect(100, 110, 160, 44, "#FFF3E0", "#FF9800", 8);
    text(180, 137, "点击立即投保", 12, 600, "#E65100", "middle");

    // 客户告知书弹窗
    rect(480, 110, 180, 44, "#FFF3E0", "#FF9800", 8);
    text(570, 130, "客户告知书弹窗", 12, 600, "#E65100", "middle");
    text(570, 148, "查看：仅记录 | 确认：截图", 10, 400, "#999", "middle");

    // --- 第二层：投保提示 + 填写信息 ---
    rect(60, 220, 170, 44, "#E3F2FD", "#2196F3", 8);
    text(145, 247, "填写投保信息", 12, 600, "#1565C0", "middle");

    rect(480, 220, 180, 44, "#E3F2FD", "#2196F3", 8);
    text(570, 247, "投保提示页", 12, 600, "#1565C0", "middle");

    // --- 第三层：条款阅读 + 确认信息 ---
    rect(60, 330, 170, 44, "#F3E5F5", "#9C27B0", 8);
    text(145, 357, "阅读保险条款", 12, 600, "#6A1B9A", "middle");

    rect(480, 330, 180, 44, "#E3F2FD", "#2196F3", 8);
    text(570, 357, "确认投保信息", 12, 600, "#1565C0", "middle");

    // --- 第四层：支付 ---
    rect(270, 450, 160, 44, "#E3F2FD", "#2196F3", 8);
    text(350, 477, "支付保费", 12, 600, "#1565C0", "middle");

    // --- 第五层：完成 ---
    rect(270, 560, 160, 48, "#E8F5E9", "#2E7D32", 10);
    text(350, 590, "投保完成", 15, 700, "#2E7D32", "middle");

    // ===== 连线 =====
    // 根 → 点击立即投保（仅记录，虚线橙色）
    line(480, 44, 180, 110, "#FF9800", true);
    label(310, 78, "仅记录", "#FF9800");

    // 根 → 客户告知书（虚线橙色）
    line(550, 44, 570, 110, "#FF9800", true);
    label(570, 78, "查看:仅记录 | 确认:截图", "#FF9800");

    // 点击立即投保 → 填写信息（实线蓝色 = 截图）
    line(180, 154, 145, 220, "#E53935", false);
    label(155, 192, "下一步:截图", "#E53935");

    // 客户告知书 → 投保提示（实线蓝色 = 截图）
    line(570, 154, 570, 220, "#E53935", false);
    label(600, 192, "确认:截图", "#E53935");

    // 填写信息 → 阅读条款（实线紫色 = 混合）
    line(145, 264, 145, 330, "#9C27B0", false);
    label(120, 305, "查看:仅记录 | 确认:截图", "#9C27B0");

    // 投保提示 → 阅读条款（实线蓝色 = 截图）
    line(570, 264, 480, 330, "#E53935", false);

    // 阅读条款 → 确认投保信息（实线蓝色 = 截图）
    line(230, 374, 480, 330, "#E53935", false);

    // 确认投保信息 → 支付（实线蓝色 = 截图）
    line(570, 264, 350, 450, "#E53935", false);
    label(480, 370, "确认投保:截图", "#E53935");

    // 支付 → 完成（实线绿色 = 截图）
    line(350, 494, 350, 560, "#4CAF50", false);
    label(370, 535, "截图", "#4CAF50");

    // ===== 节点详细说明（在右侧）=====
    var dx = 780;
    var headers = ["节点", "类型", "截图", "说明"];
    var rows = [
      ["session_start", "会话开始", "❌", "用户进入产品列表页"],
      ["click_buy", "点击立即投保", "❌", "仅记录时间，不截图"],
      ["view_client_notice", "查看客户告知书", "❌", "弹窗查看，仅记录"],
      ["confirm_client_notice", "确认客户告知书", "✅", "用户确认后截图"],
      ["confirm_notice", "确认进入投保流程", "✅", "监管强制节点，截图"],
      ["focus/input/select", "填写表单字段", "❌", "每字段记录时间，不截图"],
      ["go_agreement", "进入条款阅读页", "✅", "对整个表单页截图"],
      ["view_agreement", "查看条款弹窗", "❌", "仅记录查看时间"],
      ["confirm_agreement", "确认已阅读条款", "✅", "用户确认后截图"],
      ["confirm_apply", "确认投保并支付", "✅", "关键节点，截图"],
      ["payment", "完成支付", "✅", "支付完成，截图归档"],
    ];

  ]]></script>

